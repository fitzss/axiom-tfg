<?xml version="1.0" encoding="utf-8"?>
<!-- Simplified UR10e URDF for deterministic IK feasibility checks.
     Link lengths match the real UR10e DH parameters. -->
<robot name="ur10e">

  <link name="base_link">
    <visual><geometry><cylinder length="0.01" radius="0.06"/></geometry></visual>
  </link>

  <!-- Shoulder pan (Z-axis) -->
  <joint name="shoulder_pan_joint" type="revolute">
    <origin xyz="0 0 0.1807" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="shoulder_link"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.2832" upper="6.2832" effort="330" velocity="2.09"/>
  </joint>
  <link name="shoulder_link">
    <visual><geometry><cylinder length="0.1807" radius="0.05"/></geometry></visual>
  </link>

  <!-- Shoulder lift (Y-axis) -->
  <joint name="shoulder_lift_joint" type="revolute">
    <origin xyz="0 0 0" rpy="0 1.5708 0"/>
    <parent link="shoulder_link"/>
    <child link="upper_arm_link"/>
    <axis xyz="0 1 0"/>
    <limit lower="-6.2832" upper="6.2832" effort="330" velocity="2.09"/>
  </joint>
  <link name="upper_arm_link">
    <visual><geometry><cylinder length="0.6127" radius="0.045"/></geometry></visual>
  </link>

  <!-- Elbow (Y-axis) -->
  <joint name="elbow_joint" type="revolute">
    <origin xyz="-0.6127 0 0" rpy="0 0 0"/>
    <parent link="upper_arm_link"/>
    <child link="forearm_link"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.1416" upper="3.1416" effort="150" velocity="3.14"/>
  </joint>
  <link name="forearm_link">
    <visual><geometry><cylinder length="0.57155" radius="0.038"/></geometry></visual>
  </link>

  <!-- Wrist 1 (Y-axis) -->
  <joint name="wrist_1_joint" type="revolute">
    <origin xyz="-0.57155 0 0.17415" rpy="0 1.5708 0"/>
    <parent link="forearm_link"/>
    <child link="wrist_1_link"/>
    <axis xyz="0 1 0"/>
    <limit lower="-6.2832" upper="6.2832" effort="56" velocity="3.14"/>
  </joint>
  <link name="wrist_1_link">
    <visual><geometry><cylinder length="0.06" radius="0.03"/></geometry></visual>
  </link>

  <!-- Wrist 2 (Z-axis) -->
  <joint name="wrist_2_joint" type="revolute">
    <origin xyz="0 -0.11985 0" rpy="0 0 0"/>
    <parent link="wrist_1_link"/>
    <child link="wrist_2_link"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.2832" upper="6.2832" effort="56" velocity="3.14"/>
  </joint>
  <link name="wrist_2_link">
    <visual><geometry><cylinder length="0.06" radius="0.03"/></geometry></visual>
  </link>

  <!-- Wrist 3 (Y-axis) -->
  <joint name="wrist_3_joint" type="revolute">
    <origin xyz="0 0.11655 0" rpy="0 0 0"/>
    <parent link="wrist_2_link"/>
    <child link="ee_link"/>
    <axis xyz="0 1 0"/>
    <limit lower="-6.2832" upper="6.2832" effort="56" velocity="3.14"/>
  </joint>
  <link name="ee_link">
    <visual><geometry><sphere radius="0.01"/></geometry></visual>
  </link>

</robot>
